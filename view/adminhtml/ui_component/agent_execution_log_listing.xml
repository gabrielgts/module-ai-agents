<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">agent_execution_log_listing.agent_execution_log_listing_data_source</item>
            <item name="deps" xsi:type="string">agent_execution_log_listing.agent_execution_log_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>agent_execution_log_listing_columns</spinner>
        <deps>
            <dep>agent_execution_log_listing.agent_execution_log_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="agent_execution_log_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">entity_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Gtstudio_AiAgents::agents</aclResource>
        <dataProvider class="Gtstudio\AiAgents\Ui\DataProvider\AgentExecutionLogDataProvider"
                      name="agent_execution_log_listing_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <columns name="agent_execution_log_listing_columns">
        <settings>
            <editorConfig>
                <param name="enabled" xsi:type="boolean">false</param>
            </editorConfig>
        </settings>
        <column name="entity_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="agent_code">
            <settings>
                <filter>text</filter>
                <label translate="true">Agent Code</label>
            </settings>
        </column>
        <column name="status">
            <settings>
                <filter>select</filter>
                <label translate="true">Status</label>
            </settings>
        </column>
        <column name="triggered_by">
            <settings>
                <filter>select</filter>
                <label translate="true">Triggered By</label>
            </settings>
        </column>
        <column name="tokens_input">
            <settings>
                <label translate="true">Input Tokens</label>
            </settings>
        </column>
        <column name="tokens_output">
            <settings>
                <label translate="true">Output Tokens</label>
            </settings>
        </column>
        <column name="input">
            <settings>
                <filter>text</filter>
                <label translate="true">Input</label>
            </settings>
        </column>
        <column name="output">
            <settings>
                <label translate="true">Output</label>
            </settings>
        </column>
        <column name="error_message">
            <settings>
                <label translate="true">Error</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Executed At</label>
                <sorting>desc</sorting>
            </settings>
        </column>
    </columns>
</listing>
