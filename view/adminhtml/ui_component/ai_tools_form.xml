<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">ai_tools_form.ai_tools_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Ai Tools</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <namespace>ai_tools_form</namespace>
        <dataScope>data.general</dataScope>
        <deps>
            <dep>ai_tools_form.ai_tools_form_data_source</dep>
        </deps>
        <buttons>
            <button name="save" class="Gtstudio\AiAgents\Block\Form\AiTools\Save"/>
            <button name="back" class="Gtstudio\AiAgents\Block\Form\AiTools\Back"/>
            <button name="delete" class="Gtstudio\AiAgents\Block\Form\AiTools\Delete"/>
        </buttons>
    </settings>
    <dataSource name="ai_tools_form_data_source" component="Magento_Ui/js/form/provider">
        <settings>
            <submitUrl path="ai_tools/aitools/save"/>
        </settings>
        <dataProvider class="Gtstudio\AiAgents\Ui\DataProvider\AiToolsDataProvider" name="ai_tools_form_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general" sortOrder="10">
        <settings>
            <label translate="true">General</label>
        </settings>
        <field name="entity_id" sortOrder="0" formElement="hidden">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">entity_id</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Entity ID</label>
                <dataScope>entity_id</dataScope>
            </settings>
        </field>
        <field name="code" sortOrder="00" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">code</item>
                </item>
            </argument>
            <settings>
                <dataType>string</dataType>
                <label translate="true">Code</label>
                <dataScope>code</dataScope>
                <notice translate="true">Machine-readable identifier used by the LLM to call this tool. Use snake_case (e.g. get_order_status). Must match the key registered in ToolExecutorPool.</notice>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="description" sortOrder="10" formElement="textarea">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">description</item>
                </item>
            </argument>
            <settings>
                <dataType>string</dataType>
                <label translate="true">Description</label>
                <dataScope>description</dataScope>
                <notice translate="true">Explain what this tool does and when the LLM should use it. A clear description directly improves the model's decision-making.</notice>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <dynamicRows name="properties" sortOrder="20">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="identificationProperty" xsi:type="string">record_id</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Properties</label>
                <addButtonLabel translate="true">Add Property</addButtonLabel>
                <notice translate="true">Input parameters this tool accepts. Each row maps to a NeuronAI ToolProperty — the LLM resolves these values and passes them to the executor at runtime.</notice>
                <dndConfig>
                    <param name="enabled" xsi:type="boolean">true</param>
                    <param name="draggableElementClass" xsi:type="string">_dragged</param>
                    <param name="tableClass" xsi:type="string">table.admin__dynamic-rows</param>
                </dndConfig>
            </settings>
            <container name="record" component="Magento_Ui/js/dynamic-rows/record">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="isTemplate" xsi:type="boolean">true</item>
                        <item name="is_collection" xsi:type="boolean">true</item>
                        <item name="componentType" xsi:type="string">container</item>
                    </item>
                </argument>
                <field name="name" formElement="input" sortOrder="10">
                    <settings>
                        <dataType>string</dataType>
                        <label translate="true">Name</label>
                        <dataScope>name</dataScope>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                        </validation>
                    </settings>
                </field>
                <field name="type" formElement="select" sortOrder="20">
                    <settings>
                        <dataType>string</dataType>
                        <label translate="true">Type</label>
                        <dataScope>type</dataScope>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                        </validation>
                    </settings>
                    <formElements>
                        <select>
                            <settings>
                                <options class="Gtstudio\AiAgents\Model\Source\PropertyType"/>
                            </settings>
                        </select>
                    </formElements>
                </field>
                <field name="description" formElement="input" sortOrder="30">
                    <settings>
                        <dataType>string</dataType>
                        <label translate="true">Description</label>
                        <dataScope>description</dataScope>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                        </validation>
                    </settings>
                </field>
                <field name="required" formElement="checkbox" sortOrder="40">
                    <settings>
                        <dataType>boolean</dataType>
                        <label translate="true">Required</label>
                        <dataScope>required</dataScope>
                    </settings>
                    <formElements>
                        <checkbox>
                            <settings>
                                <valueMap>
                                    <map name="false" xsi:type="string">0</map>
                                    <map name="true" xsi:type="string">1</map>
                                </valueMap>
                                <prefer>toggle</prefer>
                            </settings>
                        </checkbox>
                    </formElements>
                </field>
                <actionDelete sortOrder="50">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="fit" xsi:type="boolean">false</item>
                        </item>
                    </argument>
                </actionDelete>
                <field name="position" formElement="input" sortOrder="60">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="dataType" xsi:type="string">number</item>
                            <item name="visible" xsi:type="boolean">false</item>
                            <item name="dataScope" xsi:type="string">position</item>
                        </item>
                    </argument>
                    <settings>
                        <label translate="true">Position</label>
                        <dataScope>position</dataScope>
                    </settings>
                </field>
            </container>
        </dynamicRows>
        <field name="additional_configs" sortOrder="40" formElement="textarea">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">additional_configs</item>
                </item>
            </argument>
            <settings>
                <dataType>string</dataType>
                <label translate="true">Additional Configs</label>
                <dataScope>additional_configs</dataScope>
                <notice translate="true">Optional JSON object forwarded to the ToolExecutorInterface implementation (e.g. API endpoints, timeouts, feature flags).</notice>
            </settings>
        </field>
    </fieldset>
</form>
